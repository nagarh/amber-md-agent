check COMPLEX
saveamberparm COMPLEX /home/hn533621/Portfolio/amber-md-agent-improvements/studies/ABL1_T315I_imatinib_TI/system/wt_complex.prmtop /home/hn533621/Portfolio/amber-md-agent-improvements/studies/ABL1_T315I_imatinib_TI/system/wt_complex.inpcrd
