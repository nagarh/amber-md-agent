source leaprc.protein.ff14SB
source leaprc.water.tip3p
source leaprc.gaff2

# Load ligand parameters (abemaciclib — same ligand as WT)
6ZV = loadMol2 ../WT_abemaciclib/ligand/6ZV.mol2
loadAmberParams ../WT_abemaciclib/ligand/6ZV.frcmod

# Load protein chains (R24C CDK4 mutant, WT CycD3)
CDK4 = loadPdb cdk4_R24C_capped.pdb
CYCD3 = loadPdb cycd3_capped.pdb

# Combine complex
COMPLEX = combine {CDK4 CYCD3 6ZV}

# Solvate with TIP3P, 10 Å buffer
solvatebox COMPLEX TIP3PBOX 10.0

# Check charge and neutralize
charge COMPLEX
addIons COMPLEX Na+ 0
addIons COMPLEX Cl- 0

# Check system
check COMPLEX

# Save
saveAmberParm COMPLEX system.prmtop system.inpcrd
quit
