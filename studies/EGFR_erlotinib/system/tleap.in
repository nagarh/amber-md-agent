source leaprc.protein.ff14SB
source leaprc.gaff2
source leaprc.water.tip3p
loadAmberParams frcmod.ionsjc_tip3p
MOL = loadMol2 /home/hn533621/Portfolio/amber-md-agent-improvements/studies/EGFR_erlotinib/system/ligand.mol2
loadAmberParams /home/hn533621/Portfolio/amber-md-agent-improvements/studies/EGFR_erlotinib/system/ligand.frcmod
protein = loadPDB /home/hn533621/Portfolio/amber-md-agent-improvements/studies/EGFR_erlotinib/system/protein_capped.pdb
system = combine {protein MOL}
solvateOct system TIP3PBOX 12.0
addions system Na+ 0
addions system Cl- 0
saveAmberParm system /home/hn533621/Portfolio/amber-md-agent-improvements/studies/EGFR_erlotinib/system/system.prmtop /home/hn533621/Portfolio/amber-md-agent-improvements/studies/EGFR_erlotinib/system/system.inpcrd
savePDB system /home/hn533621/Portfolio/amber-md-agent-improvements/studies/EGFR_erlotinib/system/system_solvated.pdb
quit