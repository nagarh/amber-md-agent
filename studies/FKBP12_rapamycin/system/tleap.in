source leaprc.protein.ff14SB
source leaprc.water.tip3p
source leaprc.gaff2
loadAmberParams /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/rap.frcmod
RAP = loadMol2 /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/rap.mol2
set default PBRadii mbondi2
receptor = loadPDB /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/protein_only.pdb
complex = combine {receptor RAP}
check complex
saveAmberParm RAP /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/lig.prmtop /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/lig.inpcrd
saveAmberParm receptor /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/rec.prmtop /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/rec.inpcrd
saveAmberParm complex /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/com.prmtop /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/com.inpcrd
solvateOct complex TIP3PBOX 12.0
addIons complex Na+ 0
addIons complex Cl- 0
saveAmberParm complex /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/com_solvated.prmtop /home/hn533621/Portfolio/amber-md-agent-improvements/studies/FKBP12_rapamycin/system/com_solvated.inpcrd
quit