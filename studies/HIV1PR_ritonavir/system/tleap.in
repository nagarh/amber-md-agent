source leaprc.protein.ff14SB
source leaprc.water.tip3p
source leaprc.gaff2
loadamberparams /home/hn533621/Portfolio/amber-md-agent/studies/HIV1PR_ritonavir/system/ritonavir.frcmod
PROT = loadPdb /home/hn533621/Portfolio/amber-md-agent/studies/HIV1PR_ritonavir/system/protein.pdb
RIT = loadMol2 /home/hn533621/Portfolio/amber-md-agent/studies/HIV1PR_ritonavir/system/ritonavir.mol2
complex = combine {PROT RIT}
charge complex
solvateOct complex TIP3PBOX 12.0
addIons complex Cl- 0
addIonsRand complex Na+ 21 Cl- 21
saveAmberParm complex /home/hn533621/Portfolio/amber-md-agent/studies/HIV1PR_ritonavir/system/system.prmtop /home/hn533621/Portfolio/amber-md-agent/studies/HIV1PR_ritonavir/system/system.inpcrd
savePdb complex /home/hn533621/Portfolio/amber-md-agent/studies/HIV1PR_ritonavir/system/system.pdb
quit
